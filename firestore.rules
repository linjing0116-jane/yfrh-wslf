rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: articles
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required, 1-200 chars)
    //   - summary: string (required, 1-500 chars)
    //   - url: string (required, valid URL)
    //   - type: string (required, enum: text, image-text, media-draft, video)
    //   - category: string (required, enum: disease, vaccine, other)
    //   - publishDate: string (required, YYYY-MM-DD)
    //   - thumbnail: string (optional, valid URL)
    //   - source: string (required, 1-100 chars)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email == "linjing0116@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    function isValidArticle(data) {
      return data.keys().hasAll(['title', 'summary', 'url', 'type', 'category', 'publishDate', 'source', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.summary is string && data.summary.size() > 0 && data.summary.size() <= 500 &&
             isValidUrl(data.url) &&
             data.type in ['text', 'image-text', 'media-draft', 'video'] &&
             data.category in ['disease', 'vaccine', 'video', 'shingles-month', 'other'] &&
             data.publishDate is string && data.publishDate.matches("^\\d{4}-\\d{2}-\\d{2}$") &&
             data.source is string && data.source.size() > 0 && data.source.size() <= 100 &&
             data.createdAt is timestamp;
    }

    match /articles/{articleId} {
      // Publicly readable for the website visitors
      allow read: if true;
      
      // Only authenticated admins can add, update or delete articles
      allow create: if isAdmin() && isValidArticle(request.resource.data);
      allow update: if isAdmin() && isValidArticle(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
